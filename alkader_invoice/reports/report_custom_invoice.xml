                                            <td style="background-color: #DDE0E4;">
                                                <t t-esc="o.amount_untaxed"/>
                                            </td>
                                            <td style="background-color: #DDE0E4;">
                                                الإجمالى الفرعى / Subtotal
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <t t-esc="o.amount_tax"/>
                                            </td>
                                            <td>
                                                ضريبة القيمة المضافة / VAT Taxes
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="background-color: #DDE0E4;">
                                                <t t-esc="o.amount_total"/>
                                            </td>
                                            <td style="background-color: #DDE0E4;">
                                                المجموع / Total
                                            </td>
                                        </tr>
                                        <t t-if="o.invoice_payments_widget">
                                            <t t-foreach="o.invoice_payments_widget['content']" t-as="payment">
                                                <tr>
                                                    <td>
                                                        <t t-esc="payment['amount']"/>
                                                    </td>
                                                    <td>
                                                        دفعت فى
                                                        <t t-esc="payment['date']"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </t>
                                        <tr>
                                            <td style="background-color: #DDE0E4;">
                                                <t t-esc="o.amount_residual"/>
                                            </td>
                                            <td style="background-color: #DDE0E4;">
                                                المبلغ المستحق / Amount Due
                                            </td>
                                        </tr>
                                        <t t-if="o.invoice_line_ids[0].sale_line_ids">
                                            <tr>
                                                <td style="background-color: #DDE0E4;">
                                                    <t t-esc="o.invoice_line_ids[0].sale_line_ids[0].order_id.payment_way.name"/>
                                                </td>
                                                <td style="background-color: #DDE0E4;">
                                                    Payment Way / طريقة الدفع
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <div style="margin-top: 10px;margin-right: 10px; direction: rtl;text-align: right;">
                                    <h1 style="padding-top: 4pt;">
                                        سياسة الاسترجاع والاستبدال
                                    </h1>
                                    <h1 style="padding-top: 10pt;">
                                        1- خلال 3 ايام من تاريخ الفاتوره.
                                    </h1>
                                    <h1 style="padding-top: 2pt;;">
                                        2- لابد من الفاتوره الاصل.
                                    </h1>
                                    <h1 style="padding-top: 2pt;">
                                        3- ان تكون بنفس حالتها المباعه.
                                    </h1>
                                    <h1 style="padding-top: 2pt;">
                                        4- قبل التركيب.
                                    </h1>
                                </div>
                            </div>
                            <p style="page-break-after:always;"/>
                        </div>
                </div>
        </xpath>
    </template>
</odoo>
